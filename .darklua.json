{
  "bundle": {
    "require_mode": {
      "name": "path"
    }
  },
  "rules": [
    "remove_comments",
    "remove_spaces",
    "compute_expression",
    "remove_unused_if_branch",
    "filter_after_early_return",
    "remove_empty_do",
    {
      "rule": "rename_variables",
      "globals": ["$default", "$roblox"]
    }
  ]
}
